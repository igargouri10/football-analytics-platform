# Copy this file to .env and fill in your values.
# Never commit .env — it is git-ignored.

# OpenAI — used for LLM test generation
OPENAI_API_KEY=sk-...

# Snowflake — used for migrated backend validation
SNOWFLAKE_ACCOUNT=your-account.snowflakecomputing.com
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=your_role
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_SCHEMA=your_schema

# AWS S3 — used for raw data ingestion
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name

# dbt DuckDB path (optional — defaults to dbt_project/target/dbt.duckdb)
# DBT_DUCKDB_PATH=dbt_project/target/dbt.duckdb
